// docs/architecture/database-architecture.md documents the ownership rules.
// docs/architecture/database-standards.md documents naming/migration conventions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Identity bounded context (docs/architecture/domain-boundaries.md).
// Named `Account`, not `User`, per docs/architecture/ddd-tactical-design.md and
// TECHNICAL_DEBT.md #1 — executed now, before any code depended on the old name.
model Account {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("accounts")
}

// docs/adr/0010-auth-token-strategy.md: opaque, hashed, rotated-on-use refresh
// tokens. `tokenHash` is the only persisted form — the raw token is never
// stored, only ever returned to the client once at issuance/rotation time.
model RefreshToken {
  id          String    @id @default(uuid())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  familyId    String
  revokedAt   DateTime?
  replacedBy  String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([accountId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// baseUrl/model/apiKeyEnvVar are all nullable: a row with any of them unset
// (e.g. the bootstrap "stub-primary"/"stub-secondary" defaults) is served by
// StubAdapter, never a real HTTP call — see
// apps/api/src/infrastructure/providers/provider-registry.adapter.ts.
// apiKeyEnvVar stores the *name* of an env var, never the key itself — the
// secret stays in process env / secret manager, per
// docs/architecture/secrets-config-management.md.
// costPerInputTokenMicros/costPerOutputTokenMicros: the ADR-0007 cost-layer
// columns, added now that a real adapter exists to read them (ADR-0007's
// "Consequences" explicitly deferred adding these until then).
model AiProviderConfig {
  id                       String   @id @default(uuid())
  providerId               String   @unique
  displayName              String
  isEnabled                Boolean  @default(true)
  priority                 Int      @default(0)
  baseUrl                  String?
  model                    String?
  apiKeyEnvVar             String?
  costPerInputTokenMicros  BigInt   @default(0)
  costPerOutputTokenMicros BigInt   @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("ai_provider_configs")
}

// Billing bounded context (docs/architecture/wallet-architecture.md, ADR-0008).
// The ledger (LedgerEntry) is authoritative; balanceMinorUnits here is a cache,
// always reconcilable against SUM(ledger_entries.amount) for this wallet.
model Wallet {
  id                String   @id @default(uuid())
  accountId         String   @unique
  currency          String
  balanceMinorUnits BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ledgerEntries LedgerEntry[]

  @@map("wallets")
}

enum LedgerEntryType {
  CREDIT
  DEBIT
  RESERVATION
  RESERVATION_RELEASE
  ROLLBACK
}

// Append-only — never updated or deleted (docs/adr/0008-wallet-ledger-pattern.md).
// amountMinorUnits is always a positive magnitude; `type` carries direction.
// Unique on (walletId, referenceId, type) rather than just (walletId,
// referenceId): a reservation and its eventual release/rollback intentionally
// share one referenceId (the originating request id) but are different types,
// so they must coexist as separate rows — only a retry of the *same*
// operation (same id AND type) should collide and no-op.
model LedgerEntry {
  id               String          @id @default(uuid())
  walletId         String
  wallet           Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type             LedgerEntryType
  amountMinorUnits BigInt
  referenceId      String
  createdAt        DateTime        @default(now())

  @@unique([walletId, referenceId, type])
  @@index([walletId])
  @@map("ledger_entries")
}

// Conversation bounded context (docs/architecture/ddd-tactical-design.md,
// docs/adr/0014-chat-orchestration.md). accountId is a plain field, not a
// `@relation`, matching Wallet's cross-aggregate-by-id-only convention above
// — Conversation and Account are separate aggregates.
model Conversation {
  id        String   @id @default(uuid())
  accountId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([accountId])
  @@map("conversations")
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

// Message IS owned by Conversation (same aggregate, unlike Account/Wallet),
// hence a real `@relation`/cascade here. `sequence` is a separate
// autoincrement column purely for deterministic ordering — two messages in
// the same conversation can share an identical `createdAt` millisecond
// (e.g. a frozen clock in tests, or fast successive real writes), which
// would make createdAt-only ordering ambiguous when reconstructing the
// message history sent back to the AI provider.
model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sequence       Int          @default(autoincrement())
  role           MessageRole
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}
