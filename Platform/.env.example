# Copy to .env for local development. Never commit a real .env file (see .gitignore).
# See docs/architecture/secrets-config-management.md for the full secrets strategy.

NODE_ENV=development

# --- apps/api ---
API_PORT=3001
API_BASE_URL=http://localhost:3001
# Comma-separated allowlist of origins permitted to call this API with credentials (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- apps/web ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# --- packages/database ---
DATABASE_URL=postgresql://aifa:aifa_local_dev@localhost:5432/aifa_platform

# --- cache ---
REDIS_URL=redis://localhost:6379

# --- AI providers (adapter credentials; never hardcode, never commit real values) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# --- observability ---
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
