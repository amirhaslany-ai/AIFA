# Copy to .env for local development. Never commit a real .env file (see .gitignore).
# See docs/architecture/secrets-config-management.md for the full secrets strategy.

NODE_ENV=development

# --- apps/api ---
API_PORT=3001
API_BASE_URL=http://localhost:3001
# Comma-separated allowlist of origins permitted to call this API with credentials (CORS).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- apps/web ---
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# --- auth (docs/adr/0010-auth-token-strategy.md) ---
# PEM-encoded Ed25519 keypair for signing access tokens. If unset, an
# ephemeral keypair is generated per-process at boot (dev-only — tokens
# won't verify across a restart). Generate real ones with:
#   node -e "const{generateKeyPairSync}=require('crypto');const{privateKey,publicKey}=generateKeyPairSync('ed25519');console.log(privateKey.export({type:'pkcs8',format:'pem'}));console.log(publicKey.export({type:'spki',format:'pem'}))"
# AUTH_JWT_PRIVATE_KEY_PEM=
# AUTH_JWT_PUBLIC_KEY_PEM=
AUTH_ACCESS_TOKEN_TTL_SECONDS=900

# --- pricing (docs/adr/0009-pricing-engine-pattern.md) ---
# Basis points; 10000 = 1.00x (no markup). Default 13000 = 1.30x.
PRICING_BASE_MARKUP_BASIS_POINTS=13000
# Minimum price per call, minor units. 0 = no floor (default — a real value is a product decision).
PRICING_MINIMUM_PRICE_MINOR_UNITS=0

# --- packages/database ---
DATABASE_URL=postgresql://aifa:aifa_local_dev@localhost:5432/aifa_platform

# --- cache ---
REDIS_URL=redis://localhost:6379

# --- AI providers (adapter credentials; never hardcode, never commit real values) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# --- observability ---
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
